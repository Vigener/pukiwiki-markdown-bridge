{
  "manifest_version": 3,
  "name": "pukiwiki-markdown-bridge",
  "version": "1.0.0",
  "description": "A Chrome Extension to edit PukiWiki using Markdown",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Open Markdown Editor"
  },
  "options_page": "src/options/index.html",
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "assets/content_script.ts-CMosxkh_.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/content_script.ts-CMosxkh_.js"
      ],
      "use_dynamic_url": false
    }
  ]
}
